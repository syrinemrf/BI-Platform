# LLM Configuration for Research Suite
# Copy this file to .env and fill in your API keys

# Ollama (local LLM) — default endpoint
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Google Gemini Flash — FREE tier (1 500 req/day, no credit card needed)
# Get your free key at: https://aistudio.google.com
GOOGLE_API_KEY=your-google-api-key-here

# Anthropic Claude API — paid alternative (optional, Gemini used first)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Confidence threshold for CGR routing (0.0-1.0)
# Tasks with LLaMA confidence < threshold are escalated to Gemini/Claude
CONFIDENCE_THRESHOLD=0.75

# DVR self-correction max attempts
DVR_MAX_ATTEMPTS=2

# Results directory
RESULTS_DIR=results
