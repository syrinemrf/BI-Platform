# Application
APP_NAME=BI Platform
APP_VERSION=3.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bi_warehouse
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis
REDIS_URL=redis://localhost:6379/0

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600

# LLM Settings (Ollama — local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
LLM_TIMEOUT=120

# Anthropic (cloud fallback for Confidence-Gated Routing)
# Leave empty to disable cloud fallback
ANTHROPIC_API_KEY=

# LLM ETL Pipeline Thresholds
CONFIDENCE_THRESHOLD=0.7
HITL_AUTO_APPROVE_THRESHOLD=0.85
HITL_AUTO_REJECT_THRESHOLD=0.3

# FAISS Vector Store
FAISS_INDEX_PATH=./faiss_store/

# ETL Settings
ETL_BATCH_SIZE=10000
ETL_MAX_WORKERS=4

# Data Quality Thresholds
DQ_COMPLETENESS_THRESHOLD=0.95
DQ_UNIQUENESS_THRESHOLD=0.99
DQ_VALIDITY_THRESHOLD=0.98

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
